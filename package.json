{
  "name": "nexa",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "generate-sitemaps": "node scripts/generate-sitemaps.js",
    "generate-robots": "node scripts/generate-robots.js",
    "validate-jsonld": "node scripts/validate-jsonld.js",
    "check-images": "node scripts/check-images.js",
    "generate-seo-report": "node scripts/generate-seo-report.js",
    "lighthouse": "node scripts/lighthouse-runner.js desktop",
    "lighthouse:desktop": "node scripts/lighthouse-runner.js desktop",
    "lighthouse:mobile": "node scripts/lighthouse-runner.js mobile",
    "accessibility": "node scripts/accessibility-runner.js",
    "seo": "node scripts/seo-runner.js",
    "validate": "npm run lint && npm run seo && npm run accessibility",
    "lint": "eslint --config .eslintrc.cjs src --ext .js,.jsx",
    "prebuild": "npm run generate-sitemaps && npm run generate-robots && npm run validate-jsonld && npm run check-images && npm run generate-seo-report",
    "build": "vite build",
    "preview": "vite preview",
    "performance-report": "node scripts/performance-report.js",
    "build-report": "node scripts/build-report.js"
  },
  "dependencies": {
    "framer-motion": "^11.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.2.0",
    "react-router-dom": "^6.23.0",
    "react-toastify": "^10.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "axe-core": "^4.12.1",
    "chrome-launcher": "^1.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "lighthouse": "^13.4.0",
    "postcss": "^8.4.38",
    "puppeteer": "^25.2.1",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.0"
  }
}
